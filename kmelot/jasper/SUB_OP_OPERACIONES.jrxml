	<parameter name="P_ID_ORDEN_PROD" class="java.math.BigDecimal"/>
	<queryString>
		<![CDATA[SELECT d.id_det_orden_ope,
       d.descripcion,
       d.tipo_costo,
       d.costo_real_total
FROM det_orden_produccion_ope d
WHERE d.orp_id_orden_prod = $P{P_ID_ORDEN_PROD}
ORDER BY d.id_det_orden_ope]]>
	</queryString>
