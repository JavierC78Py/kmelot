	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="KM kmelot"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="ireport.jasperserver.url" value="http://kmelot.online/jasperserver/"/>
	<property name="ireport.jasperserver.user" value="jasperadmin"/>
	<property name="ireport.jasperserver.reportUnit" value="/reports/kmelot/ENTREGA_INSUMO"/>
	<property name="ireport.jasperserver.report.resource" value="/reports/kmelot/ENTREGA_INSUMO_files/main_jrxml"/>
	<parameter name="P_ID_ENTREGA_INSUMO" class="java.lang.String">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="P_USUARIO" class="java.lang.String"/>
	<parameter name="P_EMPRESA" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT c.id_entrega_insumo,
       c.nro_remision,
       c.fecha_entrega,
       c.observacion,
       c.usuario_registro,
       op.nro_orden,
       op.id_orden_prod,
       e.nombre AS nombre_productor,
       e.numero_documento,
       td.abreviatura AS tipo_doc,
       se.direccion,
       se.telefono1,
       e.nro_celular,
       e.correo,
       d.id_det_entrega,
       d.cantidad_entregada,
       m.pro_id_producto_mat,
       p.descripcion AS nombre_material,
       u.descripcion || ' (' || u.abreviatura || ')' AS unidad_medida
FROM cab_entrega_insumo c,
     cab_orden_produccion op,
     entidad e,
     tipo_documento td,
     sucursal_entidad se,
     det_entrega_insumo d,
     det_orden_produccion_mat m,
     producto p,
     unidad_medida u
WHERE c.id_entrega_insumo = $P{P_ID_ENTREGA_INSUMO}
AND op.id_orden_prod = c.ord_id_orden_prod
AND e.id_entidad = op.ent_id_entidad_productor
AND td.id_tipo_documento(+) = e.tip_id_tipo_documento
AND se.ent_id_entidad(+) = e.id_entidad
AND se.es_central(+) = 'S'
AND d.ent_id_entrega_insumo = c.id_entrega_insumo
AND m.id_det_orden_mat = d.det_id_det_orden_mat
AND p.id_producto = m.pro_id_producto_mat
AND u.id_unidad_medida = m.uni_id_unidad_medida
ORDER BY d.id_det_entrega]]>
	</queryString>
