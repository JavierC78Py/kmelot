	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="P_ID_ORDEN_PROD" class="java.math.BigDecimal"/>
	<queryString>
		<![CDATA[SELECT opt.id_ord_prod_tam,
       rpt.tam_id_tamanho,
       pt.tamanho AS tamanho_desc,
       opt.cantidad
FROM orden_produccion_tamanho opt,
     receta_produccion_tamanho rpt,
     producto_tamanho pt
WHERE opt.ord_id_orden_prod = $P{P_ID_ORDEN_PROD}
AND rpt.id_tamanho_receta = opt.tam_id_tamanho_receta
AND pt.id_tamanho = rpt.tam_id_tamanho
ORDER BY pt.tamanho]]>
	</queryString>
	<field name="ID_ORD_PROD_TAM" class="java.math.BigDecimal"/>
	<field name="TAM_ID_TAMANHO" class="java.math.BigDecimal"/>
	<field name="TAMANHO_DESC" class="java.lang.String"/>
	<field name="CANTIDAD" class="java.math.BigDecimal"/>
	<variable name="V_COUNT" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{ID_ORD_PROD_TAM}]]></variableExpression>
	</variable>
	<variable name="V_TOTAL_CANTIDAD" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{CANTIDAD}]]></variableExpression>
	</variable>
