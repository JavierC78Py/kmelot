	<parameter name="P_ID_ORDEN_PROD" class="java.lang.String">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="P_USUARIO" class="java.lang.String"/>
	<parameter name="P_EMPRESA" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT c.id_orden_prod,
       c.nro_orden,
       c.fecha_orden,
       c.fecha_inicio_est,
       c.fecha_fin_real,
       c.cantidad_a_producir,
       c.costo_total_estimado,
       c.costo_total_real,
       c.estado,
       c.observacion,
       c.sexo,
       c.pro_id_producto_fin,
       p.descripcion AS nombre_producto,
       r.descripcion_receta,
       u.descripcion || ' (' || u.abreviatura || ')' AS unidad_medida,
       t.descripcion AS tipo_logo,
       do.descripcion AS deposito_origen,
       dd.descripcion AS deposito_destino,
       e.nombre AS nombre_productor,
       c.usuario_registro,
       c.fecha_registro
FROM cab_orden_produccion c,
     producto p,
     cab_receta_produccion r,
     unidad_medida u,
     tipo_logo t,
     deposito do,
     deposito dd,
     entidad e
WHERE 'NULL' = $P{P_ID_ORDEN_PROD}
AND p.id_producto = c.pro_id_producto_fin
AND r.id_receta(+) = c.rec_id_receta
AND u.id_unidad_medida(+) = r.uni_id_unidad_medida
AND t.id_tipo_logo(+) = c.tip_id_tipo_logo
AND do.id_deposito(+) = c.dep_id_deposito_orig
AND dd.id_deposito(+) = c.dep_id_deposito_dest
AND e.id_entidad(+) = c.ent_id_entidad_productor]]>
	</queryString>
