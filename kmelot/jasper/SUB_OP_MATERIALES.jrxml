	<property name="ireport.jasperserver.reportUnit" value="/reports/kmelot/ORDEN_PRODUCCION"/>
	<property name="ireport.jasperserver.report.resource" value="/reports/kmelot/ORDEN_PRODUCCION_files/SUB_OP_MATERIALES.jrxml"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="P_ID_ORDEN_PROD" class="java.math.BigDecimal"/>
	<queryString>
		<![CDATA[SELECT d.id_det_orden_mat,
       d.pro_id_producto_mat,
       p.descripcion AS nombre_material,
       u.descripcion || ' (' || u.abreviatura || ')' AS unidad_medida,
       d.cantidad_estimada,
       d.cantidad_real_consumida,
       d.costo_unitario,
       d.costo_total
FROM det_orden_produccion_mat d,
     producto p,
     unidad_medida u
WHERE d.ord_id_orden_prod = $P{P_ID_ORDEN_PROD}
AND p.id_producto = d.pro_id_producto_mat
AND u.id_unidad_medida = d.uni_id_unidad_medida
ORDER BY d.id_det_orden_mat]]>
	</queryString>
	<field name="ID_DET_ORDEN_MAT" class="java.math.BigDecimal"/>
	<field name="PRO_ID_PRODUCTO_MAT" class="java.math.BigDecimal"/>
	<field name="NOMBRE_MATERIAL" class="java.lang.String"/>
	<field name="UNIDAD_MEDIDA" class="java.lang.String"/>
	<field name="CANTIDAD_ESTIMADA" class="java.math.BigDecimal"/>
	<field name="CANTIDAD_REAL_CONSUMIDA" class="java.math.BigDecimal"/>
	<field name="COSTO_UNITARIO" class="java.math.BigDecimal"/>
	<field name="COSTO_TOTAL" class="java.math.BigDecimal"/>
	<variable name="V_COUNT" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{ID_DET_ORDEN_MAT}]]></variableExpression>
	</variable>
	<variable name="V_TOTAL_COSTO" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{COSTO_TOTAL}]]></variableExpression>
	</variable>
