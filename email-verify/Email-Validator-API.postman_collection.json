    {
      "name": "Performance Tests",
      "item": [
        {
          "name": "Cache Performance Test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Primera llamada",
                  "if (pm.iteration === 0) {",
                  "    pm.test(\"First call - not from cache\", function () {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData.fromCache).to.be.false;",
                  "    });",
                  "    pm.environment.set('firstCallTime', pm.response.responseTime);",
                  "}",
                  "",
                  "// Segunda llamada",
                  "if (pm.iteration === 1) {",
                  "    pm.test(\"Second call - from cache\", function () {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData.fromCache).to.be.true;",
                  "    });",
                  "    ",
                  "    pm.test(\"Cached response is faster\", function () {",
                  "        var firstCall = parseInt(pm.environment.get('firstCallTime'));",
                  "        var secondCall = pm.response.responseTime;",
                  "        pm.expect(secondCall).to.be.below(firstCall);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"cache-test@santaclara.com.py\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/validate-email",
              "host": ["{{base_url}}"],
              "path": ["api", "validate-email"]
            },
            "description": "Test para verificar mejora de performance con cache (ejecutar 2 veces)"
          },
          "response": []
        }
      ],
