{
  "name": "email-validator-service",
  "version": "1.0.0",
  "description": "Servicio de validación de emails con soporte para dominios paraguayos",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "node tests/test-emails.js",
    "test:integration": "jest tests/integration.test.js",
    "docker:build": "docker build -t email-validator .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
