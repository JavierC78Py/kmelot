  "keywords": [
    "email",
    "validation",
    "paraguay",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "deep-email-validator": "^0.1.21",
    "ioredis": "^5.3.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "axios": "^1.6.2",
    "jest": "^29.7.0"
  }
}