# Server Configuration
NODE_ENV=development
PORT=3150
HOST=0.0.0.0

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache Configuration (seconds)
MX_CACHE_TTL=86400
EMAIL_CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin API Key (generar uno seguro en producción)
ADMIN_API_KEY=change-this-in-production-use-uuid-or-strong-random

# CORS Configuration
CORS_ORIGIN=*

# Validation Settings
SMTP_VALIDATION_ENABLED=false
VALIDATION_TIMEOUT=5000

# Logging
LOG_LEVEL=info