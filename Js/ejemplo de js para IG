/*  OTRO con control update */ */
(function($) {
    function update(model) {
        var salKey = model.getFieldKey("MONTO_SERVICIO"),
            ncKey  = model.getFieldKey("MONTO_NC"),
            ivaKey = model.getFieldKey("IVA_ID"),
            total = 0,
            total10 = 0,
            total0 = 0,
            totalNc = 0,
            cantidad = 0,
            total5 = 0;
        //console.log(">> starting sum MONTO_SERVICIO column");
        model.forEach(function(record, index, id) {
            // Obtener el valor como string
            var salStr = record[salKey];
            var ncStr = record[ncKey];
            var sal = 0;
            var nc = 0;
            if (salStr !== null && salStr !== undefined) {
                // Si es un string, convertirlo correctamente
                if (typeof salStr === 'string') {
                    // Primero eliminar cualquier separador de miles (puntos)
                    // Luego reemplazar coma decimal por punto
                    salStr = salStr.replace(/\./g, '').replace(',', '.');
                }
                sal = parseFloat(salStr);
            }
            if (ncStr !== null && ncStr !== undefined) {
                if (typeof ncStr === 'string') {
                    ncStr = ncStr.replace(/\./g, '').replace(',', '.');
                }
                nc = parseFloat(ncStr);
            }
            var meta = model.getRecordMetadata(id);
            // Verificar que no sean NaN antes de sumar
            if (!meta.deleted && !meta.agg) {
                // Para el monto de servicio
                if (!isNaN(sal)) {
                    // Siempre sumamos al total general
                    total += sal;
                    cantidad += 1;
                    // Verificar el valor de IVA_ID
                    var idIva = record[ivaKey];
                    //console.log("IVA_ID:", idIva, "MONTO_SERVICIO:", sal);
                    // Clasificar según IVA_ID
                    if (idIva == 2) {
                        total10 += sal;
                        //console.log("Sumando al TOTAL_10:", sal, "- Acumulado:", total10);
                    }
                    else if (idIva == 3) {
                        total5 += sal;
                        //console.log("Sumando al TOTAL_5:", sal, "- Acumulado:", total5);
                    }
                    else if (idIva == 1 || idIva == 4) {
                        total0 += sal;
                        //console.log("Sumando al TOTAL_0:", sal, "- Acumulado:", total0);
                    }
                }
                // Para la nota de crédito
                if (!isNaN(nc)) {
                    totalNc += nc;
                }
            }
        });
        //console.log(">> setting totals - TOTAL: " + total.toFixed(2) + ", TOTAL_10: " + total10.toFixed(2) + 
        //           ", TOTAL_5: " + total5.toFixed(2) + ", TOTAL_0: " + total0.toFixed(2) + ", TOTAL_NC: " + totalNc.toFixed(2));
        // Asegurar que los items existen antes de actualizar
        try {
            $s("P905_TOTAL", total.toFixed(2));
            $s("P905_TOTAL_10", total10.toFixed(2));
            $s("P905_TOTAL_5", total5.toFixed(2));
            $s("P905_TOTAL_0", total0.toFixed(2));
            $s("P905_TOTAL_NC", totalNc.toFixed(2));
            $s("P905_CANT_SERVICIOS", cantidad);
        } catch (e) {
            console.error("Error al actualizar items:", e);
        }
    }
